{erl_opts, [debug_info]}.

{deps, [
    {cowboy, "2.12.0"},
    {gun, "2.1.0"},
    {jiffy, "1.1.2"},
    {hackney, "1.20.1"},
    {recon, "2.5.6"},
    {fs, "8.6.1"}
]}.

{project_plugins, [
    rebar3_proper
]}.

{relx, [
    {release, {cli_proxy, "0.1.0"}, [
        cli_proxy,
        sasl
    ]},
    {dev_mode, true},
    {include_erts, false},
    {extended_start_script, true},
    {vm_args, "config/vm.args"},
    {sys_config, "config/sys.config"}
]}.

{profiles, [
    {prod, [
        {relx, [
            {dev_mode, false},
            {include_erts, true}
        ]}
    ]},
    {test, [
        {deps, [
            {proper, "1.4.0"},
            {meck, "0.9.2"}
        ]}
    ]}
]}.

{shell, [
    {apps, [cli_proxy]}
]}.

{cover_enabled, true}.
{cover_opts, [verbose]}.

{dialyzer, [
    {warnings, [
        unmatched_returns,
        error_handling,
        underspecs
    ]}
]}.
